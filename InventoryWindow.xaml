<Window x:Class="PaperbellAppDotNet.InventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventory (stok sudah dicetak)"
        Height="620"
        Width="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        PreviewKeyDown="Window_PreviewKeyDown">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <TextBlock TextWrapping="Wrap" Foreground="#444" Margin="0,0,0,8"
                       Text="Pilih produk dari Data Map (Search Alias), set qty, lalu Tambah â€” atau isi nomor order Shopee untuk menambah semua baris item sekaligus (mis. retur). Key item = NoRef + SKUInduk di Data Map (= item_key sync). Stok dipakai dari tombol 'Use inventory' di daftar order."/>
            <GroupBox Header="Tambah dari nomor order Shopee (semua item)" Margin="0,0,0,10" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Order SN:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="TxtOrderSn" Grid.Column="1" Height="28" VerticalContentAlignment="Center"
                             ToolTip="Nomor order seperti di Shopee / kolom Order SN (harus sudah pernah di-sync ke database)."/>
                    <Button Grid.Column="2" Content="Tambah semua item order" Margin="10,0,0,0" Padding="12,6"
                            Click="BtnAddFromOrder_Click"/>
                </Grid>
            </GroupBox>
            <TextBlock Text="Atau pilih produk manual:" Foreground="#555" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtSearch" Grid.Column="0" Height="28" VerticalContentAlignment="Center"
                         TextChanged="TxtSearch_TextChanged"
                         PreviewKeyDown="TxtSearch_PreviewKeyDown"/>
                <TextBox x:Name="TxtQty" Grid.Column="1" Height="28" Margin="8,0,0,0" VerticalContentAlignment="Center"
                         Text="1" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Content="Tambah" Margin="8,0,0,0" Padding="14,6" Click="BtnAdd_Click"/>
            </Grid>
            <Border BorderBrush="#CCC" BorderThickness="1" Background="White" MaxHeight="200">
                <ListBox x:Name="SuggestList" MaxHeight="200"
                         DisplayMemberPath="Display"
                         PreviewMouseLeftButtonUp="SuggestList_PreviewMouseLeftButtonUp"/>
            </Border>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Tutup" Padding="16,6" MinWidth="100" IsDefault="True" Click="BtnClose_Click"/>
        </StackPanel>

        <DataGrid x:Name="InvGrid"
                  AutoGenerateColumns="False"
                  HeadersVisibility="Column"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  CellEditEnding="InvGrid_CellEditEnding"
                  Margin="0,0,0,0">
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="8,6"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="MinHeight" Value="34"/>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Produk" Binding="{Binding ItemName}" Width="*" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="6,2"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Variasi" Binding="{Binding ModelName}" Width="200" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="6,2"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="NoRef" Binding="{Binding NoRef}" Width="130" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="6,2"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="SKU induk" Binding="{Binding SkuInduk}" Width="130" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="6,2"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Qty" Binding="{Binding Qty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="4,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="4,0"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="" Width="90">
                    <DataGridTemplateColumn.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="2"/>
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Hapus"
                                    Margin="0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Padding="8,4"
                                    Click="BtnDeleteRow_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
