<Window x:Class="PaperbellAppDotNet.RandomPagesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Random pages (Planner / Loose Leaf)"
        Height="520"
        Width="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid x:Name="RootLayout" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,12"
                   Foreground="#444"
                   Text="Grup (P/L) dari Data Map. N = banyak file PDF berbeda (acak). Planner: tiap PDF 1 halaman â†’ total N halaman. Loose Leaf: tiap PDF satu spread bolak-balik (hal. pertama ganjil + berikutnya, mis. 3â€“4) â†’ total 2Ã—N halaman. N â‰¤ jumlah PDF di pool."/>

        <GroupBox Grid.Row="1" Header="Grup" Padding="8" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="RbPlanner" Content="Planner (P)" IsChecked="True" Margin="0,0,16,0" GroupName="GrpKind"/>
                <RadioButton x:Name="RbLoose" Content="Loose Leaf (L)" GroupName="GrpKind"/>
            </StackPanel>
        </GroupBox>

        <TextBlock x:Name="TxtPoolInfo" Grid.Row="2" TextWrapping="Wrap" Margin="0,0,0,10"
                   Foreground="#333" FontSize="13"/>

        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <GroupBox x:Name="GbCount" Grid.Column="0" Header="N (jumlah PDF)" Padding="8"
                      ToolTip="Planner: total = N halaman. Loose Leaf: total = 2Ã—N; tiap PDF satu pasangan berurutan dengan halaman pertama ganjil (mis. 3â€“4).">
                <TextBox x:Name="TxtCount" Text="5" VerticalContentAlignment="Center" Height="28"/>
            </GroupBox>
            <GroupBox Grid.Column="2" Header="Ukuran kertas" Padding="8">
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="RbA5" Content="A5" IsChecked="True" Margin="0,0,12,0" GroupName="GrpPaper"/>
                    <RadioButton x:Name="RbB5" Content="B5" GroupName="GrpPaper"/>
                </StackPanel>
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="4" Header="Exclude produk (opsional)" Padding="8" Margin="0,0,0,10"
                  ToolTip="Pisahkan dengan koma/semicolon/baris baru. Jika label PDF mengandung kata ini, file tidak ikut random.">
            <TextBox x:Name="TxtExclude"
                     MinHeight="56"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>
        </GroupBox>

        <TextBlock x:Name="TxtHint" Grid.Row="5" TextWrapping="Wrap" VerticalAlignment="Top" Margin="0,0,0,8" Foreground="#666" FontSize="12"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnOk" Content="OK" Width="88" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click"/>
            <Button x:Name="BtnCancel" Content="Batal" Width="88" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
