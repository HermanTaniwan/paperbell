<Window x:Class="PaperbellAppDotNet.PrintLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Printing log"
        Height="520"
        Width="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock FontSize="14" FontWeight="SemiBold" Text="Printing log (newest first)" Margin="0,0,0,8"/>

        <TextBox x:Name="LogBox" Grid.Row="1"
                 FontFamily="Consolas"
                 FontSize="12"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Refresh" Width="90" Margin="0,0,8,0" Click="Refresh_Click"/>
            <Button Content="Close" Width="90" IsCancel="True" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
